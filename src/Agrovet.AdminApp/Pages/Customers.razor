@page "/customers"
@inject HttpClient Http

<div class="container-fluid mt-4">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;">
        <div>
            <h4 style="font-weight: 900; color: #e0e0e0; margin: 0;">👥 Customers</h4>
            <p style="color: #666; font-size: 0.85rem; margin: 4px 0 0;">All registered customers on the platform</p>
        </div>
        <div style="display: flex; gap: 12px; align-items: center;">
            <input
                @oninput="OnSearch"
                placeholder="🔍 Search customers..."
                style="
                    padding: 10px 18px; border: 1px solid #e0e0e0;
                    border-radius: 50px; width: 240px; font-size: 0.9rem;
                    outline: none; background: #1e1e2e;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
                "
            />
            <button @onclick="ExportCsv" style="
                background: #1b5e20; color: white; border: none;
                padding: 10px 20px; border-radius: 50px;
                font-weight: 700; cursor: pointer; font-size: 0.9rem;
            ">
                ⬇ Export CSV
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px;">
        <div style="background: #1e1e2e; border-radius: 14px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <p style="color: #666; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px;">Total Customers</p>
            <h3 style="font-weight: 900; color: #1b5e20; margin: 0;">@allCustomers.Count</h3>
        </div>
        <div style="background: #1e1e2e; border-radius: 14px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <p style="color: #666; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px;">Admins</p>
            <h3 style="font-weight: 900; color: #1565c0; margin: 0;">@allCustomers.Count(c => c.Role == "Admin")</h3>
        </div>
        <div style="background: #1e1e2e; border-radius: 14px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <p style="color: #666; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px;">Regular Users</p>
            <h3 style="font-weight: 900; color: #e65100; margin: 0;">@allCustomers.Count(c => c.Role != "Admin")</h3>
        </div>
        <div style="background: #1e1e2e; border-radius: 14px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <p style="color: #666; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px;">This Month</p>
            <h3 style="font-weight: 900; color: #6a1b9a; margin: 0;">@allCustomers.Count(c => c.CreatedAt.Month == DateTime.Now.Month)</h3>
        </div>
    </div>

    <!-- Table -->
    <div style="background: #1e1e2e; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden;">

        @if (isLoading)
        {
            <div style="text-align: center; padding: 60px;">
                <div class="spinner-border text-success"></div>
                <p class="mt-3 text-muted">Loading customers...</p>
            </div>
        }
        else if (filteredCustomers.Count == 0)
        {
            <div style="text-align: center; padding: 60px;">
                <div style="font-size: 3rem;">👥</div>
                <h5 style="color: #666; margin-top: 12px;">No customers found</h5>
            </div>
        }
        else
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #16213e; border-bottom: 2px solid #e8eaf0;">
                        <th style="@ThStyle">#</th>
                        <th style="@ThStyle">Full Name</th>
                        <th style="@ThStyle">Email</th>
                        <th style="@ThStyle">Phone Number</th>
                        <th style="@ThStyle">Role</th>
                        <th style="@ThStyle">Registered On</th>
                        <th style="@ThStyle">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @{int index = 1;}
                    @foreach (var customer in filteredCustomers)
                    {
                        <tr style="border-bottom: 1px solid #2a2a3e; transition: background 0.2s;"
                            onmouseover="this.style.background='#f8fffe'"
                            onmouseout="this.style.background='white'">
                            <td style="@TdStyle color: #666; font-weight: 600;">@index</td>
                            <td style="@TdStyle">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div style="
                                        width: 36px; height: 36px; border-radius: 50%;
                                        background: linear-gradient(135deg, #1b5e20, #4caf50);
                                        display: flex; align-items: center; justify-content: center;
                                        color: white; font-weight: 800; font-size: 0.85rem;
                                        flex-shrink: 0;
                                    ">
                                        @customer.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <span style="font-weight: 700; color: #e0e0e0;">@customer.FullName</span>
                                </div>
                            </td>
                            <td style="@TdStyle color: #aaa;">@customer.Email</td>
                            <td style="@TdStyle color: #aaa;">@customer.PhoneNumber</td>
                            <td style="@TdStyle">
                                <span style="
                                    padding: 4px 12px; border-radius: 50px; font-size: 0.78rem; font-weight: 700;
                                    background: @(customer.Role == "Admin" ? "#e3f2fd" : "#f3e5f5");
                                    color: @(customer.Role == "Admin" ? "#1565c0" : "#6a1b9a");
                                ">
                                    @customer.Role
                                </span>
                            </td>
                            <td style="@TdStyle color: #777; font-size: 0.85rem;">
                                @customer.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                            <td style="@TdStyle">
                                <span style="
                                    padding: 4px 12px; border-radius: 50px; font-size: 0.78rem; font-weight: 700;
                                    background: #e8f5e9; color: #2e7d32;
                                ">
                                    ✅ Active
                                </span>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>

            <!-- Footer -->
            <div style="padding: 16px 24px; background: #16213e; display: flex; justify-content: space-between; align-items: center;">
                <p style="margin: 0; color: #666; font-size: 0.85rem;">
                    Showing @filteredCustomers.Count of @allCustomers.Count customers
                </p>
                <p style="margin: 0; color: #666; font-size: 0.85rem;">
                    Last updated: @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")
                </p>
            </div>
        }
    </div>
</div>

@code {
    private List<CustomerDto> allCustomers = new();
    private List<CustomerDto> filteredCustomers = new();
    private bool isLoading = true;
    private string searchQuery = string.Empty;

    private string ThStyle => "padding: 14px 20px; text-align: left; font-size: 0.78rem; font-weight: 800; color: #888; text-transform: uppercase; letter-spacing: 1px;";
    private string TdStyle => "padding: 14px 20px; font-size: 0.88rem;";

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        isLoading = true;
        try
        {
            allCustomers = await Http.GetFromJsonAsync<List<CustomerDto>>("api/auth/users") ?? new();
            filteredCustomers = allCustomers.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString()?.ToLower() ?? string.Empty;
        filteredCustomers = string.IsNullOrEmpty(searchQuery)
            ? allCustomers.ToList()
            : allCustomers.Where(c =>
                c.FullName.ToLower().Contains(searchQuery) ||
                c.Email.ToLower().Contains(searchQuery) ||
                c.PhoneNumber.Contains(searchQuery) ||
                c.Role.ToLower().Contains(searchQuery)
            ).ToList();
    }

    private void ExportCsv()
    {
        Console.WriteLine("Export triggered");
    }

    public class CustomerDto
    {
        public string Id { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
    }
}
