@page "/checkout"
@inject Agrovet.WebApp.Services.AuthStateService AuthState
@inject HttpClient Http
@inject NavigationManager Navigation

<div style="background: #f5f6fa; min-height: calc(100vh - 65px); padding: 32px;">
    <div style="max-width: 1000px; margin: 0 auto;">

        <div style="margin-bottom: 28px;">
            <h4 style="font-weight: 900; color: #1a1a2e; margin: 0;">🧾 Checkout</h4>
            <p style="color: #999; font-size: 0.88rem; margin: 4px 0 0;">Complete your order and payment</p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 80px;">
                <div class="spinner-border text-success" style="width: 3rem; height: 3rem;"></div>
                <p class="mt-3 text-muted">Loading your order...</p>
            </div>
        }
        else
        {
            <div style="display: grid; grid-template-columns: 1fr 380px; gap: 24px;">

                <!-- Left — Delivery Details -->
                <div>
                    <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 20px;">
                        <h5 style="font-weight: 800; color: #1a1a2e; margin: 0 0 20px;">📦 Delivery Details</h5>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div style="background: #ffebee; color: #c62828; padding: 12px 16px; border-radius: 10px; font-weight: 600; margin-bottom: 20px; border-left: 4px solid #c62828; font-size: 0.88rem;">
                                ⚠️ @errorMessage
                            </div>
                        }

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div style="grid-column: span 2;">
                                <label style="@LabelStyle">Full Name</label>
                                <input @bind="fullName" placeholder="Enter your full name" style="@InputStyle"
                                    onfocus="this.style.borderColor='#1b5e20'" onblur="this.style.borderColor='#e8eaf0'" />
                            </div>
                            <div>
                                <label style="@LabelStyle">Phone Number</label>
                                <input @bind="phoneNumber" placeholder="e.g. 0712345678" style="@InputStyle"
                                    onfocus="this.style.borderColor='#1b5e20'" onblur="this.style.borderColor='#e8eaf0'" />
                            </div>
                            <div>
                                <label style="@LabelStyle">Town / City</label>
                                <input @bind="town" placeholder="e.g. Nakuru" style="@InputStyle"
                                    onfocus="this.style.borderColor='#1b5e20'" onblur="this.style.borderColor='#e8eaf0'" />
                            </div>
                            <div style="grid-column: span 2;">
                                <label style="@LabelStyle">Delivery Address</label>
                                <textarea @bind="deliveryAddress" rows="3" placeholder="Enter your full delivery address"
                                    style="@InputStyle resize: none;"
                                    onfocus="this.style.borderColor='#1b5e20'" onblur="this.style.borderColor='#e8eaf0'"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Payment -->
                    <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
                        <h5 style="font-weight: 800; color: #1a1a2e; margin: 0 0 20px;">📱 M-Pesa Payment</h5>

                        <div style="background: #e8f5e9; border-radius: 12px; padding: 16px; margin-bottom: 20px; display: flex; align-items: center; gap: 12px;">
                            <div style="font-size: 2rem;">📱</div>
                            <div>
                                <p style="font-weight: 700; color: #1b5e20; margin: 0; font-size: 0.9rem;">Pay with M-Pesa</p>
                                <p style="color: #555; font-size: 0.8rem; margin: 2px 0 0;">You will receive an STK push on your phone</p>
                            </div>
                        </div>

                        <div>
                            <label style="@LabelStyle">M-Pesa Phone Number</label>
                            <input @bind="mpesaPhone" placeholder="e.g. 0712345678" style="@InputStyle"
                                onfocus="this.style.borderColor='#1b5e20'" onblur="this.style.borderColor='#e8eaf0'" />
                            <small style="color: #999; font-size: 0.78rem;">Enter the phone number registered with M-Pesa</small>
                        </div>

                        @if (!string.IsNullOrEmpty(statusMessage))
                        {
                            <div style="
                                margin-top: 16px; padding: 14px 16px; border-radius: 10px;
                                font-weight: 600; font-size: 0.88rem;
                                background: @(alertClass == "alert-success" ? "#e8f5e9" : alertClass == "alert-danger" ? "#ffebee" : "#e3f2fd");
                                color: @(alertClass == "alert-success" ? "#2e7d32" : alertClass == "alert-danger" ? "#c62828" : "#1565c0");
                                border-left: 4px solid @(alertClass == "alert-success" ? "#2e7d32" : alertClass == "alert-danger" ? "#c62828" : "#1565c0");
                            ">@statusMessage</div>
                        }

                        @if (orderPlaced)
                        {
                            <button @onclick="GoToOrders" style="
                                width: 100%; padding: 12px; margin-top: 16px;
                                background: #e8f5e9; color: #1b5e20;
                                border: 2px solid #1b5e20; border-radius: 12px;
                                font-weight: 700; cursor: pointer; font-size: 0.9rem;
                            ">📦 View My Orders</button>
                        }
                    </div>
                </div>

                <!-- Right — Order Summary -->
                <div>
                    <div style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); position: sticky; top: 90px;">
                        <h5 style="font-weight: 800; color: #1a1a2e; margin: 0 0 20px;">🛒 Order Summary</h5>

                        @foreach (var item in cartItems)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f5f5f5;">
                                <div>
                                    <p style="font-weight: 700; color: #1a1a2e; margin: 0; font-size: 0.88rem;">@item.Product?.Name</p>
                                    <p style="color: #999; font-size: 0.75rem; margin: 2px 0 0;">Qty: @item.Quantity</p>
                                </div>
                                <span style="font-weight: 700; color: #1b5e20; font-size: 0.88rem;">
                                    KSh @(item.Quantity * (item.Product?.Price ?? 0))
                                </span>
                            </div>
                        }

                        <div style="margin-top: 16px;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                <span style="color: #999; font-size: 0.88rem;">Subtotal</span>
                                <span style="font-weight: 700; font-size: 0.88rem;">KSh @subtotal</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                <span style="color: #999; font-size: 0.88rem;">Delivery Fee (5%)</span>
                                <span style="font-weight: 700; color: #e65100; font-size: 0.88rem;">KSh @deliveryFee</span>
                            </div>
                        </div>

                        <div style="background: #f8fffe; border-radius: 12px; padding: 16px; border: 1px solid #e8f5e9; margin: 16px 0 8px; display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 800; color: #1a1a2e;">Total</span>
                            <span style="font-weight: 900; color: #1b5e20; font-size: 1.4rem;">KSh @orderTotal</span>
                        </div>

                        <p style="color: #999; font-size: 0.75rem; margin: 0 0 16px; text-align: center;">
                            Includes 5% delivery fee of KSh @deliveryFee
                        </p>

                        <button @onclick="PlaceOrder" disabled="@(isProcessing || orderPlaced)" style="
                            width: 100%; padding: 15px;
                            background: @(orderPlaced ? "#ccc" : "linear-gradient(135deg, #1b5e20, #2e7d32)");
                            color: white; border: none; border-radius: 12px;
                            font-weight: 700; cursor: @(orderPlaced ? "not-allowed" : "pointer"); font-size: 1rem;
                            box-shadow: 0 4px 15px rgba(27,94,32,0.3);
                        ">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Processing...</span>
                            }
                            else if (orderPlaced)
                            {
                                <span>✅ Order Placed!</span>
                            }
                            else
                            {
                                <span>💳 Pay KSh @orderTotal via M-Pesa</span>
                            }
                        </button>

                        <button @onclick="@(() => Navigation.NavigateTo("/cart"))" style="
                            width: 100%; padding: 12px; margin-top: 10px;
                            background: transparent; color: #666;
                            border: 1.5px solid #e0e0e0; border-radius: 12px;
                            font-weight: 600; cursor: pointer; font-size: 0.9rem;
                        ">← Back to Cart</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<CartItemDto> cartItems = new();
    private bool isLoading = true;
    private bool isProcessing = false;
    private bool orderPlaced = false;
    private string fullName = string.Empty;
    private string phoneNumber = string.Empty;
    private string town = string.Empty;
    private string deliveryAddress = string.Empty;
    private string mpesaPhone = string.Empty;
    private decimal subtotal = 0;
    private decimal deliveryFee = 0;
    private decimal orderTotal = 0;
    private string statusMessage = string.Empty;
    private string alertClass = "alert-info";
    private string errorMessage = string.Empty;

    private string LabelStyle => "font-weight: 700; font-size: 0.85rem; color: #444; display: block; margin-bottom: 7px;";
    private string InputStyle => "width: 100%; padding: 13px 16px; border: 1.5px solid #e8eaf0; border-radius: 10px; font-size: 0.9rem; outline: none; box-sizing: border-box; background: #fafafa; transition: border 0.2s;";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsLoggedIn) { Navigation.NavigateTo("/login"); return; }
        fullName = AuthState.FullName ?? string.Empty;
        await LoadCart();
    }

    private async Task LoadCart()
    {
        isLoading = true;
        try
        {
            cartItems = await Http.GetFromJsonAsync<List<CartItemDto>>($"api/cart/{AuthState.UserId}") ?? new();
            CalculateTotals();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally { isLoading = false; }
    }

    private void CalculateTotals()
    {
        subtotal = cartItems.Sum(i => i.Quantity * (i.Product?.Price ?? 0));
        deliveryFee = Math.Round(subtotal * 0.05m, 0);
        orderTotal = subtotal + deliveryFee;
    }

    private async Task PlaceOrder()
    {
        errorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(fullName)) { errorMessage = "Full name is required."; return; }
        if (string.IsNullOrWhiteSpace(phoneNumber)) { errorMessage = "Phone number is required."; return; }
        if (string.IsNullOrWhiteSpace(deliveryAddress)) { errorMessage = "Delivery address is required."; return; }
        if (string.IsNullOrWhiteSpace(mpesaPhone)) { errorMessage = "M-Pesa phone number is required."; return; }
        if (cartItems.Count == 0) { errorMessage = "Your cart is empty."; return; }

        isProcessing = true;
        statusMessage = "⏳ Creating your order...";
        alertClass = "alert-info";

        try
        {
            // Step 1 — Create the order in the database
            var orderRequest = new
            {
                UserId = AuthState.UserId,
                DeliveryAddress = $"{fullName}, {phoneNumber}, {town}, {deliveryAddress}",
                TotalAmount = orderTotal,
                OrderItems = cartItems.Select(i => new
                {
                    ProductId = i.ProductId,
                    Quantity = i.Quantity,
                    UnitPrice = i.Product?.Price ?? 0
                }).ToList()
            };

            var orderResponse = await Http.PostAsJsonAsync("api/orders", orderRequest);

            if (!orderResponse.IsSuccessStatusCode)
            {
                statusMessage = "⚠️ Failed to create order. Please try again.";
                alertClass = "alert-danger";
                isProcessing = false;
                return;
            }

            var createdOrder = await orderResponse.Content.ReadFromJsonAsync<OrderResponseDto>();

            // Step 2 — Initiate M-Pesa payment
            statusMessage = "⏳ Initiating M-Pesa payment...";
            alertClass = "alert-info";

            var paymentRequest = new
            {
                PhoneNumber = mpesaPhone,
                Amount = orderTotal,
                OrderReference = createdOrder?.Id.ToString() ?? Guid.NewGuid().ToString()
            };

            var paymentResponse = await Http.PostAsJsonAsync("api/mpesa/pay", paymentRequest);

            if (paymentResponse.IsSuccessStatusCode)
            {
                // Step 3 — Clear the cart
                await Http.DeleteAsync($"api/cart/clear/{AuthState.UserId}");

                orderPlaced = true;
                statusMessage = "✅ Order placed! Check your phone for the M-Pesa prompt to complete payment.";
                alertClass = "alert-success";
            }
            else
            {
                statusMessage = "⚠️ Order created but payment initiation failed. Please contact support.";
                alertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            alertClass = "alert-danger";
        }

        isProcessing = false;
    }

    private void GoToOrders() => Navigation.NavigateTo("/orders");

    public class CartItemDto
    {
        public Guid Id { get; set; }
        public Guid ProductId { get; set; }
        public int Quantity { get; set; }
        public ProductDto? Product { get; set; }
    }

    public class ProductDto
    {
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
    }

    public class OrderResponseDto
    {
        public Guid Id { get; set; }
    }
}
