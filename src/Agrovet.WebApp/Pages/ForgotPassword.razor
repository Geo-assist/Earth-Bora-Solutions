@page "/forgot-password"
@inject HttpClient Http
@inject NavigationManager Navigation

<div style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f6fa;
">
    <div style="width: 100%; max-width: 440px; padding: 24px;">

        <!-- Card -->
        <div style="
            background: white; border-radius: 20px;
            padding: 40px; box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        ">
            <!-- Logo -->
            <div style="text-align: center; margin-bottom: 28px;">
                <div style="font-size: 2.5rem; margin-bottom: 8px;">🔐</div>
                <h4 style="font-weight: 900; color: #1a1a2e; margin: 0;">Reset Password</h4>
                <p style="color: #999; font-size: 0.88rem; margin: 6px 0 0;">
                    Enter your email and new password below
                </p>
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div style="
                    background: #e8f5e9; color: #2e7d32;
                    padding: 14px 16px; border-radius: 10px;
                    font-weight: 600; margin-bottom: 20px;
                    border-left: 4px solid #2e7d32; font-size: 0.88rem;
                ">✅ @successMessage</div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="
                    background: #ffebee; color: #c62828;
                    padding: 14px 16px; border-radius: 10px;
                    font-weight: 600; margin-bottom: 20px;
                    border-left: 4px solid #c62828; font-size: 0.88rem;
                ">⚠️ @errorMessage</div>
            }

            <div style="margin-bottom: 16px;">
                <label style="font-weight: 700; font-size: 0.85rem; color: #444; display: block; margin-bottom: 7px;">
                    Email Address
                </label>
                <input
                    @bind="email"
                    type="email"
                    placeholder="you@example.com"
                    style="
                        width: 100%; padding: 13px 16px;
                        border: 1.5px solid #e8eaf0; border-radius: 10px;
                        font-size: 0.9rem; outline: none; box-sizing: border-box;
                        background: #fafafa; transition: border 0.2s;
                    "
                    onfocus="this.style.borderColor='#1b5e20'"
                    onblur="this.style.borderColor='#e8eaf0'"
                />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="font-weight: 700; font-size: 0.85rem; color: #444; display: block; margin-bottom: 7px;">
                    New Password
                </label>
                <div style="position: relative;">
                    <input
                        @bind="newPassword"
                        type="@passwordType"
                        placeholder="Enter new password"
                        style="
                            width: 100%; padding: 13px 48px 13px 16px;
                            border: 1.5px solid #e8eaf0; border-radius: 10px;
                            font-size: 0.9rem; outline: none; box-sizing: border-box;
                            background: #fafafa; transition: border 0.2s;
                        "
                        onfocus="this.style.borderColor='#1b5e20'"
                        onblur="this.style.borderColor='#e8eaf0'"
                    />
                    <button @onclick="TogglePassword" style="
                        position: absolute; right: 14px; top: 50%;
                        transform: translateY(-50%);
                        background: none; border: none; cursor: pointer;
                        color: #999; font-size: 0.82rem; font-weight: 600;
                    ">@passwordToggle</button>
                </div>
            </div>

            <div style="margin-bottom: 24px;">
                <label style="font-weight: 700; font-size: 0.85rem; color: #444; display: block; margin-bottom: 7px;">
                    Confirm New Password
                </label>
                <input
                    @bind="confirmPassword"
                    type="password"
                    placeholder="Repeat new password"
                    style="
                        width: 100%; padding: 13px 16px;
                        border: 1.5px solid #e8eaf0; border-radius: 10px;
                        font-size: 0.9rem; outline: none; box-sizing: border-box;
                        background: #fafafa; transition: border 0.2s;
                    "
                    onfocus="this.style.borderColor='#1b5e20'"
                    onblur="this.style.borderColor='#e8eaf0'"
                />
            </div>

            <button @onclick="HandleReset" disabled="@isLoading" style="
                width: 100%; padding: 14px;
                background: linear-gradient(135deg, #1b5e20, #2e7d32);
                color: white; border: none; border-radius: 10px;
                font-size: 1rem; font-weight: 700; cursor: pointer;
                box-shadow: 0 4px 15px rgba(27,94,32,0.35);
                margin-bottom: 16px;
            ">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Resetting...</span>
                }
                else
                {
                    <span>🔐 Reset Password</span>
                }
            </button>

            <p style="text-align: center; color: #999; font-size: 0.88rem; margin: 0;">
                Remember your password?
                <a href="/login" style="color: #1b5e20; font-weight: 700; text-decoration: none;">
                    Sign in here
                </a>
            </p>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = false;
    private string passwordType = "password";
    private string passwordToggle = "Show";

    private void TogglePassword()
    {
        passwordType = passwordType == "password" ? "text" : "password";
        passwordToggle = passwordToggle == "Show" ? "Hide" : "Show";
    }

    private async Task HandleReset()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(email)) { errorMessage = "Email is required."; return; }
        if (!email.Contains("@") || !email.Contains(".")) { errorMessage = "Please enter a valid email."; return; }
        if (string.IsNullOrWhiteSpace(newPassword)) { errorMessage = "New password is required."; return; }
        if (newPassword.Length < 8) { errorMessage = "Password must be at least 8 characters."; return; }
        if (newPassword != confirmPassword) { errorMessage = "Passwords do not match."; return; }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", new
            {
                Email = email,
                NewPassword = newPassword
            });

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Password reset successfully! You can now login.";
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = "Email not found. Please check and try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally { isLoading = false; }
    }
}
